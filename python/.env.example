SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_KEY=your_service_role_key
SUPABASE_JWT_SECRET=your_jwt_secret
DATA_DIR=./data
FETCH_TIMEOUT_SECONDS=300
# Optional: add Vercel production URL to CORS allowed origins (only needed for direct browser access)
# CORS_ALLOWED_ORIGIN=https://your-app.vercel.app

# PROJ-37: MT5 Bridge Worker (separate Windows host with installed MT5 Terminal).
# The shared secret must be identical on the bridge and the backend.
MT5_BRIDGE_URL=https://your-mt5-bridge.example.com
MT5_BRIDGE_TOKEN=replace_with_a_long_random_string
