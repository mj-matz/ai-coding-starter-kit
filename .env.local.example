# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# FastAPI Data Fetcher Service
FASTAPI_URL=http://localhost:8000
NEXT_PUBLIC_FASTAPI_URL=http://localhost:8000

# Anthropic Claude API (PROJ-22: MQL Converter, PROJ-21: AI Strategy Generator)
# Server-side only — never use NEXT_PUBLIC_ prefix
ANTHROPIC_API_KEY=your-anthropic-api-key

# ForexFactory – Economic Calendar Sync (kein API-Key nötig, nur privat nutzen)
# POST /api/admin/sync-calendar  →  synct aktuelle + nächste Woche

# PROJ-37: MT5 Bridge Worker — set on the Python backend (Railway), not Next.js.
# The Next.js layer never speaks to the bridge directly.
# MT5_BRIDGE_URL=https://your-bridge-host.example.com
# MT5_BRIDGE_TOKEN=shared-secret-must-match-bridge
